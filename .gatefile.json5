{
	$use: "./node_modules/.bin",

	play_review: {
		name: "Review scratch play changes",
		// src/play is disposable experiment space. Never auto-commit it without explicit human approval.
		match: "src/play/**/*.{js,cjs,mjs}",
		run: {
			label: "Review scratch play changes",
			message: [
				"Scratch experiments changed under src/play.",
				"These files stay outside automatic commit flow.",
			],
			guidance: [
				"Review the play diff.",
				"Re-run gate with --allow-play when manual review is done.",
			],
			status: "fail",
		},
		suppress: "--allow-play",
		critical: true,
	},

	markdown_review: {
		name: "Review protected markdown",
		// README stays auto-committable. Other markdown requires explicit human review.
		match: [["**/*.md", "!README.md", "!**/README.md"]],
		run: {
			label: "Review protected markdown",
			message: [
				"Protected markdown changed.",
				"Only README.md is allowed through auto-commit.",
			],
			guidance: [
				"Review the markdown diff.",
				"Re-run gate with --allow-protected-markdown when review is done.",
			],
			status: "fail",
		},
		suppress: "--allow-protected-markdown",
		critical: true,
	},

	gatefile: {
		name: "Validate gatefile",
		// Gate control files do not belong in other gate selectors. Validate this one directly.
		match: ".gatefile.json5",
		run: "gate ls",
	},

	format: {
		name: "Check TypeScript formatting",
		// Dirty experiments in src/play stay outside formatter pressure. Runtime TS stays strict.
		match: ["src/index.ts", "src/app/**/*.ts", "src/modules/**/*.ts", "dprint.json"],
		run: "dprint check",
	},

	lint: {
		name: "Lint app and module TypeScript",
		// src/play is JS scratch space and is ignored by lint config on purpose.
		match: [
			"src/index.ts",
			"src/app/**/*.ts",
			"src/modules/**/*.ts",
			".oxlintrc.json",
			"tsconfig.json",
		],
		run: "oxlint --type-aware --tsconfig tsconfig.json .",
	},

	typecheck: {
		name: "Typecheck app and module TypeScript",
		// Only TypeScript runtime surfaces participate here. src/play has no type contract.
		match: ["src/index.ts", "src/app/**/*.ts", "src/modules/**/*.ts", "tsconfig.json"],
		run: "tsc --noEmit",
	},

	dupes: {
		name: "Detect duplication across app, modules, and play",
		// Keep duplication pressure on reusable code and scratch experiments alike.
		match: [
			"src/index.ts",
			"src/app/**/*.ts",
			"src/modules/**/*.ts",
			"src/play/**/*.{js,cjs,mjs}",
			".jscpd.json",
		],
		run: "jscpd --config .jscpd.json .",
	},

	unused: {
		name: "Check unused TypeScript code and package usage",
		// Knip covers exported TS surfaces and package metadata. src/play stays outside that contract.
		match: [
			"src/index.ts",
			"src/app/**/*.ts",
			"src/modules/**/*.ts",
			"knip.json",
			"tsconfig.json",
			"package.json",
		],
		run: "knip",
	},

	autocommit: {
		name: "Autocommit validated safe changes",
		// Protected paths are blocked by critical review gates above. This gate commits only safe repo surfaces.
		match: [
			".gatefile.json5",
			".gitignore",
			".jscpd.json",
			".oxlintrc.json",
			"dprint.json",
			"knip.json",
			"package.json",
			"package-lock.json",
			"tsconfig.json",
			"README.md",
			"src/index.ts",
			"src/app/**/*.ts",
			"src/modules/**/*.ts",
		],
		run: {
			label: "Validated diff ready for commit",
			message: "Validated diff ready for commit.",
			status: "pass",
		},
		hooks: {
			after: "@commit",
		},
	},
}